                  "key": "content-type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"id\": 1,\n  \"title\": \"Clean Code\",\n  \"description\": \"A handbook of agile software craftsmanship\",\n  \"publication_year\": 2008,\n  \"language\": \"EN\",\n  \"pages\": 464,\n  \"publisher\": \"Prentice Hall\",\n  \"cover_image\": \"https://example.com/clean-code.jpg\",\n  \"category_id\": 1,\n  \"created_at\": \"2024-01-15T10:30:00Z\",\n  \"updated_at\": null\n}"
            }
          ],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Validar status code",
                  "pm.test(\"Status code is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "// Validar response time",
                  "pm.test(\"Response time is less than 500ms\", function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});",
                  "",
                  "// Validar que la respuesta sea JSON válido",
                  "pm.test(\"Response is valid JSON\", function () {",
                  "  pm.response.to.have.jsonBody();",
                  "});",
                  "",
                  "// Validar campos principales",
                  "pm.test(\"Book has title\", function () {",
                  "  pm.expect(pm.response.json()).to.have.property('title');",
                  "});",
                  "",
                  "pm.test(\"Book has id\", function () {",
                  "  pm.expect(pm.response.json()).to.have.property('id');",
                  "});",
                  "",
                  "pm.test(\"Book has created_at\", function () {",
                  "  pm.expect(pm.response.json()).to.have.property('created_at');",
                  "});",
                  "",
                  "// Guardar el ID del libro en variable de entorno",
                  "if (pm.response.json().id) {",
                  "  pm.environment.set(\"book_id\", pm.response.json().id);",
                  "}"
                ]
              }
            }
          ]
